-- =============================================
-- 6. COMPANIES (Công ty IT nổi tiếng tại VN)
-- =============================================
INSERT INTO companies (id, name, description, website, logo, address, city, scale, created_at, updated_at) VALUES
-- Big Tech VN
('c0000001-0000-0000-0000-000000000001', 'FPT Software',
 'FPT Software là công ty công nghệ hàng đầu Việt Nam, chuyên cung cấp dịch vụ chuyển đổi số, phần mềm và giải pháp CNTT cho khách hàng toàn cầu. Với hơn 30.000 nhân viên, FPT Software có mặt tại 30 quốc gia.',
 'https://fptsoftware.com', 'https://upload.wikimedia.org/wikipedia/commons/thumb/1/11/FPT_logo_2010.svg/1200px-FPT_logo_2010.svg.png',
 'Tòa nhà FPT, Phố Duy Tân, Cầu Giấy', 'Hà Nội', '5000+', NOW(), NOW()),

('c0000001-0000-0000-0000-000000000002', 'VNG Corporation',
 'VNG là công ty công nghệ hàng đầu Việt Nam, sở hữu các sản phẩm nổi tiếng như Zalo, ZaloPay, Zing MP3. VNG là kỳ lân công nghệ đầu tiên của Việt Nam với định giá hơn 1 tỷ USD.',
 'https://vng.com.vn', 'https://upload.wikimedia.org/wikipedia/vi/thumb/f/fe/VNG_Corporation_Logo.svg/1200px-VNG_Corporation_Logo.svg.png',
 '182 Lê Đại Hành, Quận 11', 'Hồ Chí Minh', '3000-5000', NOW(), NOW()),

('c0000001-0000-0000-0000-000000000003', 'Viettel Group',
 'Viettel là tập đoàn viễn thông và công nghệ lớn nhất Việt Nam, hoạt động tại 13 quốc gia. Viettel Solutions và Viettel Cyber Security là các đơn vị CNTT chủ lực.',
 'https://viettel.com.vn', 'https://upload.wikimedia.org/wikipedia/commons/thumb/b/bf/Viettel_logo_2021.svg/1200px-Viettel_logo_2021.svg.png',
 'Số 1 Trần Hữu Dực, Nam Từ Liêm', 'Hà Nội', '5000+', NOW(), NOW()),

('c0000001-0000-0000-0000-000000000004', 'Tiki',
 'Tiki là một trong những sàn thương mại điện tử hàng đầu Việt Nam, nổi tiếng với dịch vụ giao hàng nhanh TikiNOW 2h. Tiki đang đẩy mạnh ứng dụng AI và Big Data vào trải nghiệm mua sắm.',
 'https://tiki.vn', 'https://salt.tikicdn.com/ts/upload/e4/49/6c/3c5b7dfcf96ede1c6e16b960b49f1ded.png',
 '52 Út Tịch, Quận Tân Bình', 'Hồ Chí Minh', '1000-3000', NOW(), NOW()),

('c0000001-0000-0000-0000-000000000005', 'Shopee Vietnam',
 'Shopee là nền tảng thương mại điện tử hàng đầu Đông Nam Á. Trung tâm R&D tại Việt Nam phát triển các tính năng AI, Search, Payment cho toàn khu vực.',
 'https://shopee.vn', 'https://upload.wikimedia.org/wikipedia/commons/thumb/f/fe/Shopee.svg/1200px-Shopee.svg.png',
 'Tầng 28, Bitexco Financial Tower, Quận 1', 'Hồ Chí Minh', '1000-3000', NOW(), NOW()),

('c0000001-0000-0000-0000-000000000006', 'MoMo',
 'MoMo là ví điện tử phổ biến nhất Việt Nam với hơn 35 triệu người dùng. MoMo cung cấp các dịch vụ thanh toán, chuyển tiền và tài chính kỹ thuật số.',
 'https://momo.vn', 'https://upload.wikimedia.org/wikipedia/vi/f/fe/MoMo_Logo.png',
 '285 Cách Mạng Tháng 8, Quận 10', 'Hồ Chí Minh', '1000-3000', NOW(), NOW()),

('c0000001-0000-0000-0000-000000000007', 'VNPAY',
 'VNPAY là công ty fintech hàng đầu Việt Nam, cung cấp giải pháp thanh toán điện tử cho ngân hàng, doanh nghiệp. VNPAY-QR đã trở thành chuẩn thanh toán QR quốc gia.',
 'https://vnpay.vn', 'https://vinadesign.vn/uploads/images/2023/05/vnpay-logo-vinadesign-25-12-57-55.jpg',
 '22 Láng Hạ, Ba Đình', 'Hà Nội', '1000-3000', NOW(), NOW()),

('c0000001-0000-0000-0000-000000000008', 'KMS Technology',
 'KMS Technology là công ty phát triển phần mềm có trụ sở tại Mỹ với trung tâm phát triển lớn tại Việt Nam. KMS cung cấp dịch vụ outsourcing và product development cho thị trường quốc tế.',
 'https://kms-technology.com', 'https://kms-technology.com/wp-content/uploads/2021/01/KMS-Technology-Logo.png',
 '76 Lê Lai, Quận 1', 'Hồ Chí Minh', '1000-3000', NOW(), NOW()),

('c0000001-0000-0000-0000-000000000009', 'NashTech',
 'NashTech (thuộc Harvey Nash Group) là công ty outsourcing IT hàng đầu, chuyên về .NET, Java, Cloud và Data Engineering cho khách hàng châu Âu.',
 'https://nashtechglobal.com', 'https://nashtechglobal.com/wp-content/uploads/2022/03/nashtech-logo.png',
 'Tầng 9-10, Etown Central, Quận 4', 'Hồ Chí Minh', '1000-3000', NOW(), NOW()),

('c0000001-0000-0000-0000-000000000010', 'Axon Active Vietnam',
 'Axon Active là công ty Thụy Sĩ chuyên phát triển phần mềm Agile tại Việt Nam, nổi tiếng với văn hóa làm việc hiện đại và môi trường quốc tế.',
 'https://axonactive.com', 'https://axonactive.com/wp-content/uploads/2020/07/logo-axon.png',
 '2B Trường Sơn, Quận Tân Bình', 'Hồ Chí Minh', '500-1000', NOW(), NOW()),

('c0000001-0000-0000-0000-000000000011', 'TMA Solutions',
 'TMA Solutions là một trong những công ty phần mềm lớn nhất Việt Nam với hơn 4000 kỹ sư, chuyên phát triển phần mềm cho khách hàng quốc tế.',
 'https://tmasolutions.com', 'https://tmasolutions.com/wp-content/uploads/2020/01/TMA-Logo.png',
 'Quang Trung Software City, Quận 12', 'Hồ Chí Minh', '3000-5000', NOW(), NOW()),

('c0000001-0000-0000-0000-000000000012', 'CMC Global',
 'CMC Global thuộc Tập đoàn CMC, chuyên cung cấp dịch vụ IT outsourcing, cloud computing và chuyển đổi số cho doanh nghiệp trong nước và quốc tế.',
 'https://cmcglobal.com.vn', 'https://cmcglobal.com.vn/wp-content/uploads/2020/07/logo-cmc.png',
 '11 Duy Tân, Cầu Giấy', 'Hà Nội', '1000-3000', NOW(), NOW()),

('c0000001-0000-0000-0000-000000000013', 'VNLife (VNPay Group)',
 'VNLife là hệ sinh thái fintech bao gồm VNPAY, với sứ mệnh số hóa thanh toán và dịch vụ tài chính tại Việt Nam.',
 'https://vnlife.vn', NULL,
 '22 Láng Hạ, Ba Đình', 'Hà Nội', '1000-3000', NOW(), NOW()),

('c0000001-0000-0000-0000-000000000014', 'BE Group (be)',
 'be là ứng dụng gọi xe công nghệ Việt Nam, cạnh tranh trực tiếp với Grab. be còn cung cấp dịch vụ beFinancial và beDelivery.',
 'https://be.com.vn', 'https://be.com.vn/wp-content/uploads/2022/07/logo-be.png',
 'Quận 1', 'Hồ Chí Minh', '500-1000', NOW(), NOW()),

('c0000001-0000-0000-0000-000000000015', 'ZaloPay (by VNG)',
 'ZaloPay là ví điện tử thuộc VNG, tích hợp trên nền tảng Zalo với hơn 75 triệu người dùng, cung cấp thanh toán, chuyển tiền và dịch vụ tài chính.',
 'https://zalopay.vn', NULL,
 '182 Lê Đại Hành, Quận 11', 'Hồ Chí Minh', '500-1000', NOW(), NOW()),

('c0000001-0000-0000-0000-000000000016', 'Ến Solutions (ến)',
 'Ến Solutions là công ty phần mềm Việt Nam chuyên phát triển sản phẩm SaaS, ERP, và giải pháp doanh nghiệp.',
 'https://ens.vn', NULL,
 'Quận 7', 'Hồ Chí Minh', '100-500', NOW(), NOW()),

('c0000001-0000-0000-0000-000000000017', 'Grab Vietnam',
 'Grab là siêu ứng dụng hàng đầu Đông Nam Á. R&D Center tại Việt Nam phát triển các tính năng AI, Maps, Payment cho toàn khu vực.',
 'https://grab.com', 'https://upload.wikimedia.org/wikipedia/commons/thumb/f/f3/Grab_%28application%29_logo_2.svg/1200px-Grab_%28application%29_logo_2.svg.png',
 'Tầng 30, Bitexco Financial Tower, Quận 1', 'Hồ Chí Minh', '500-1000', NOW(), NOW()),

('c0000001-0000-0000-0000-000000000018', 'Ến Consulting (KPMG Vietnam)',
 'KPMG Việt Nam cung cấp dịch vụ kiểm toán, thuế và tư vấn, đồng thời có đội ngũ IT Advisory mạnh chuyên về digital transformation.',
 'https://kpmg.com/vn', NULL,
 'Tầng 10, Sunwah Tower, Quận 1', 'Hồ Chí Minh', '500-1000', NOW(), NOW()),

('c0000001-0000-0000-0000-000000000019', 'Sendo',
 'Sendo là sàn thương mại điện tử Việt Nam thuộc FPT, tập trung vào thị trường tỉnh lẻ với hơn 500.000 nhà bán.',
 'https://sendo.vn', 'https://media3.scdn.vn/img4/2021/10_25/B3tCMcamVE5a2FEfz2wE.png',
 'Số 7 Tôn Thất Thuyết, Cầu Giấy', 'Hà Nội', '500-1000', NOW(), NOW()),

('c0000001-0000-0000-0000-000000000020', 'Samsung Vietnam R&D',
 'Samsung Vietnam Mobile R&D Center (SVMC) là trung tâm R&D lớn nhất của Samsung tại Đông Nam Á, phát triển phần mềm cho Galaxy và One UI.',
 'https://samsung.com/vn', 'https://upload.wikimedia.org/wikipedia/commons/thumb/2/24/Samsung_Logo.svg/1200px-Samsung_Logo.svg.png',
