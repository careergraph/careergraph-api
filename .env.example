# ============================================
# CareerGraph API - Environment Variables
# Copy to ..env (or ...env.dev / ...env.prod) and fill values
# ============================================

# --- Server ---
SPRING_PROFILES_ACTIVE=dev
SERVER_PORT=8080
SERVER_PORT_EXPOSE=8090
SERVER_PORT_CONTAINER=8080
SERVER_SERVLET_CONTEXT_PATH=/careergraph/api/v1
SERVER_FORWARD_HEADERS_STRATEGY=framework
SWAGGER_SERVER_URL=

# --- Docker data path (optional) ---
DATA_PATH=./data

# --- PostgreSQL ---
POSTGRES_PORT=5442
POSTGRES_DB=careergraph
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5442/careergraph
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=postgres

# --- Redis ---
REDIS_PORT=6479
REDIS_PASSWORD=
SPRING_REDIS_HOST=localhost
SPRING_REDIS_PORT=6479
SPRING_REDIS_PASSWORD=
SPRING_REDIS_SSL=false
SPRING_REDIS_TIMEOUT=2000ms
SPRING_REDIS_DATABASE=0

# --- Elasticsearch ---
ES_PORT=9200
ES_TRANSPORT_PORT=9300
ES_HEAP_SIZE=512m
ELASTIC_PASSWORD=elastic
SPRING_ELASTICSEARCH_URIS=http://localhost:9200

# --- Datasource pool / JPA tuning ---
DATASOURCE_MAX_POOL_SIZE=10
DATASOURCE_MIN_IDLE=2
DATASOURCE_CONNECTION_TIMEOUT_MS=30000
DATASOURCE_IDLE_TIMEOUT_MS=600000
DATASOURCE_MAX_LIFETIME_MS=1800000
JPA_DDL_AUTO=update
JPA_SHOW_SQL=false
JPA_FORMAT_SQL=false

# --- App seed data ---
APP_SEED_ENABLED=true
APP_SEED_SCRIPT_PATH=init-scripts/seed-basic.sql
APP_SEED_CHECK_TABLE=jobs
APP_SEED_MIN_ROW_COUNT=1

# --- Messaging / Notification (Phase 5) ---
# RTC server URL for backend push calls (/internal/notify, /internal/unread-counts)
SOCKET_SERVER_URL=http://localhost:4000
# Must match INTERNAL_API_KEY on careergraph-rtc
SOCKET_INTERNAL_API_KEY=dev-secret-change-in-prod
# Rate limit NEW_MESSAGE notification creation per thread
NOTIFICATION_MESSAGE_COOLDOWN_MINUTES=2
# Aggregate application status changes in this window
NOTIFICATION_AGGREGATION_WINDOW_MINUTES=5
# Keep notifications for this many days before scheduled cleanup
NOTIFICATION_CLEANUP_DAYS_TO_KEEP=90

# --- Redis pool tuning ---
REDIS_POOL_MAX_ACTIVE=8
REDIS_POOL_MAX_IDLE=8
REDIS_POOL_MIN_IDLE=0
REDIS_POOL_MAX_WAIT=-1ms
REDIS_SHUTDOWN_TIMEOUT=100ms

# --- Auth & Cookie ---
JWT_SIGNER_KEY=change-me-with-strong-random-key
JWT_VALID_DURATION=3600
JWT_REFRESHABLE_DURATION=36000
COOKIE_SECURE=false
COOKIE_SAMESITE=Lax

# --- Google OAuth & AI ---
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_PROJECT_ID=
GEMINI_API_KEY=
GEMINI_CHAT_MODEL=gemini-2.5-flash
GEMINI_EMBEDDING_MODEL=text-embedding-005
HUGGING_FACE_KEY=

# --- Integrations ---
FAST_API_BASE_URL=http://localhost:8000
EMBEDDING_SERVICE_URL=http://localhost:8000
WEB_BASE_URL=http://localhost:5000
HELP_CENTER_URL=
COMPANY_ADDRESS=1 Vo Van Ngan, Thu Duc, TP. Ho Chi Minh, Viet Nam
DIGEST_ENABLED=true
DIGEST_BUILD_CRON=0 0 7 ? * MON
DIGEST_SEND_CRON=0 0 8 ? * MON

# --- Auto AI screening (sau khi ứng viên apply; async) ---
# Cần bật global + bật trên từng job (HR toggle trên JobsGrid)
APPLICATION_AI_SCREENING_ENABLED=false
APPLICATION_AI_SCREENING_MIN_SCORE_PERCENT=50
APPLICATION_AI_SCREENING_MAX_PROMPT_CHARS=14000
RESUME_EXTRACTION_MAX_DOWNLOAD_BYTES=15728640
RESUME_EXTRACTION_MAX_STORED_CHARS=50000
RESUME_EXTRACTION_ALLOWED_HOSTS=res.cloudinary.com
CACHE_USER_TTL=300

# --- File storage ---
INTEGRATION_S3_ENDPOINT=
INTEGRATION_S3_ACCESS_KEY=
INTEGRATION_S3_SECRET_KEY=
INTEGRATION_S3_BUCKET=
INTEGRATION_S3_REGION=

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- Mail ---
SUPPORT_EMAIL=support@careergraph.com
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_TRANSPORT_PROTOCOL=smtp
MAIL_SMTP_AUTH=true
MAIL_STARTTLS_ENABLE=true
MAIL_DEBUG=false

# --- Multipart ---
MULTIPART_MAX_FILE_SIZE=10MB
MULTIPART_MAX_REQUEST_SIZE=20MB

# --- Swagger basic auth (if your app uses it) ---
SWAGGER_USERNAME=
SWAGGER_PASSWORD=

# --- CORS ---
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5000,http://localhost:5173,http://localhost:8000,https://thinz.io.vn,http://thinz.io.vn,http://api.thinz.io.vn,https://api.thinz.io.vn,http://hr.thinz.io.vn,https://hr.thinz.io.vn
CORS_ALLOWED_METHODS=*
CORS_ALLOWED_HEADERS=*

# --- Spring Security public endpoints (CSV, relative to context-path) ---
SECURITY_PUBLIC_ENDPOINTS=/auth/**,/jobs/**,/companies/**,/swagger-ui.html,/swagger-ui/**,/swagger-resources/**,/v3/api-docs,/v3/api-docs/**,/v3/api-docs.yaml,/api-docs/**,/webjars/**,/error,/actuator/health,/actuator/health/**

CV_KEYWORDS_STRATEGY=HEURISTIC
CV_KEYWORDS_MAX_CHARS=300

# --- Elasticsearch sync / embedding runtime ---
# Bật đồng bộ Job -> Elasticsearch khi app start.
APP_ES_SYNC_JOBS_ENABLED=false
# Bật đồng bộ Candidate -> Elasticsearch khi app start.
APP_ES_SYNC_CANDIDATES_ENABLED=false
# Khi local embedding lỗi, cho phép fallback sang Gemini.
APP_ES_ALLOW_GEMINI_FALLBACK=true
# true: gọi local FastAPI embedding trước. false: gọi Gemini trước.
APP_EMBED_USE_LOCAL_FIRST=true
# Ghi đè riêng cho EmbedService; để trống hoặc giống APP_ES_ALLOW_GEMINI_FALLBACK nếu muốn đồng nhất hành vi.
APP_EMBED_ALLOW_GEMINI_FALLBACK=true
# Mỗi lần sync jobs chỉ embed tối đa từng này bản ghi thay đổi.
APP_ES_MAX_EMBEDDINGS_PER_RUN=50
# Mỗi lần sync candidates chỉ embed tối đa từng này hồ sơ thay đổi.
APP_ES_MAX_CANDIDATE_EMBEDDINGS_PER_RUN=30
# Bật/tắt toàn bộ scheduler sync nền.
APP_ES_CRON_ENABLED=true
# Bật scheduler sync jobs.
APP_ES_CRON_JOBS_ENABLED=true
# Bật scheduler sync candidates.
APP_ES_CRON_CANDIDATES_ENABLED=true
# Chu kỳ lặp giữa 2 lần chạy job sync (ms).
APP_ES_CRON_JOBS_FIXED_DELAY_MS=120000
# Độ trễ trước lần chạy job sync đầu tiên sau khi app khởi động (ms).
APP_ES_CRON_JOBS_INITIAL_DELAY_MS=120000
# Số job tối đa được xử lý trong mỗi lần scheduler chạy.
APP_ES_CRON_JOBS_BATCH_SIZE=25
# Chu kỳ lặp giữa 2 lần chạy candidate sync (ms).
APP_ES_CRON_CANDIDATES_FIXED_DELAY_MS=240000
# Độ trễ trước lần chạy candidate sync đầu tiên sau khi app khởi động (ms).
APP_ES_CRON_CANDIDATES_INITIAL_DELAY_MS=240000
# Số candidate tối đa được xử lý trong mỗi lần scheduler chạy.
APP_ES_CRON_CANDIDATES_BATCH_SIZE=10

# --- Spring AI retry / embedding dimension ---
# Số lần retry tối đa khi gọi Gemini/Spring AI. =1 nghĩa là không retry thêm.
SPRING_AI_RETRY_MAX_ATTEMPTS=1
# Có retry cả lỗi 4xx hay không. Thường để false để tránh lặp lại request sai.
SPRING_AI_RETRY_ON_CLIENT_ERRORS=false
# Danh sách HTTP code không retry. 429 thường để bỏ qua vì rate limit dễ bị khuếch đại.
SPRING_AI_RETRY_EXCLUDE_ON_HTTP_CODES=429
# Thời gian chờ trước lần retry đầu tiên.
SPRING_AI_RETRY_BACKOFF_INITIAL_INTERVAL=1ms
# Thời gian chờ tối đa giữa các lần retry.
SPRING_AI_RETRY_BACKOFF_MAX_INTERVAL=2ms
# Hệ số nhân backoff giữa các lần retry.
SPRING_AI_RETRY_BACKOFF_MULTIPLIER=2
# Số chiều vector embedding mà backend mong đợi từ local/Gemini để khớp mapping Elasticsearch.
EMBEDDING_SERVICE_EXPECTED_DIMENSIONS=3072
