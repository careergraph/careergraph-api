# ============================================
# CareerGraph API - Environment Variables
# Copy to .env (or .env.dev / .env.prod) and fill values
# ============================================

# --- Server ---
SPRING_PROFILES_ACTIVE=dev
SERVER_PORT=8080
SERVER_PORT_EXPOSE=8090
SERVER_PORT_CONTAINER=8080
SERVER_SERVLET_CONTEXT_PATH=/careergraph/api/v1

# --- Docker data path (optional) ---
DATA_PATH=./data

# --- PostgreSQL ---
POSTGRES_PORT=5442
POSTGRES_DB=careergraph
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5442/careergraph
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=postgres

# --- Redis ---
REDIS_PORT=6479
REDIS_PASSWORD=
SPRING_REDIS_HOST=localhost
SPRING_REDIS_PORT=6479
SPRING_REDIS_PASSWORD=
SPRING_REDIS_SSL=false
SPRING_REDIS_TIMEOUT=2000ms
SPRING_REDIS_DATABASE=0

# --- Elasticsearch ---
ES_PORT=9200
ES_TRANSPORT_PORT=9300
ES_HEAP_SIZE=512m
ELASTIC_PASSWORD=elastic
SPRING_ELASTICSEARCH_URIS=http://localhost:9200

# --- Datasource pool / JPA tuning ---
DATASOURCE_MAX_POOL_SIZE=10
DATASOURCE_MIN_IDLE=2
DATASOURCE_CONNECTION_TIMEOUT_MS=30000
DATASOURCE_IDLE_TIMEOUT_MS=600000
DATASOURCE_MAX_LIFETIME_MS=1800000
JPA_DDL_AUTO=update
JPA_SHOW_SQL=false
JPA_FORMAT_SQL=false

# --- App seed data ---
APP_SEED_ENABLED=true
APP_SEED_SCRIPT_PATH=init-scripts/seed-basic.sql
APP_SEED_CHECK_TABLE=jobs
APP_SEED_MIN_ROW_COUNT=1

# --- Redis pool tuning ---
REDIS_POOL_MAX_ACTIVE=8
REDIS_POOL_MAX_IDLE=8
REDIS_POOL_MIN_IDLE=0
REDIS_POOL_MAX_WAIT=-1ms
REDIS_SHUTDOWN_TIMEOUT=100ms

# --- Auth & Cookie ---
JWT_SIGNER_KEY=change-me-with-strong-random-key
JWT_VALID_DURATION=3600
JWT_REFRESHABLE_DURATION=36000
COOKIE_SECURE=false
COOKIE_SAMESITE=Lax

# --- Google OAuth & AI ---
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_PROJECT_ID=
GEMINI_API_KEY=
GEMINI_CHAT_MODEL=gemini-2.5-flash
GEMINI_EMBEDDING_MODEL=text-embedding-005
HUGGING_FACE_KEY=

# --- Integrations ---
FAST_API_BASE_URL=http://localhost:8000
EMBEDDING_SERVICE_URL=http://localhost:8000
CACHE_USER_TTL=300

# --- File storage ---
INTEGRATION_S3_ENDPOINT=
INTEGRATION_S3_ACCESS_KEY=
INTEGRATION_S3_SECRET_KEY=
INTEGRATION_S3_BUCKET=
INTEGRATION_S3_REGION=

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- Mail ---
SUPPORT_EMAIL=support@careergraph.com
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_TRANSPORT_PROTOCOL=smtp
MAIL_SMTP_AUTH=true
MAIL_STARTTLS_ENABLE=true
MAIL_DEBUG=false

# --- Multipart ---
MULTIPART_MAX_FILE_SIZE=10MB
MULTIPART_MAX_REQUEST_SIZE=20MB

# --- Swagger basic auth (if your app uses it) ---
SWAGGER_USERNAME=
SWAGGER_PASSWORD=
