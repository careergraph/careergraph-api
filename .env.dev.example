SPRING_PROFILES_ACTIVE=dev

SERVER_PORT=8080
SERVER_SERVLET_CONTEXT_PATH=/careergraph/api/v1
SERVER_FORWARD_HEADERS_STRATEGY=framework
SWAGGER_SERVER_URL=

SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5442/careergraph
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=postgres
DATASOURCE_MAX_POOL_SIZE=10
DATASOURCE_MIN_IDLE=2

SPRING_REDIS_HOST=localhost
SPRING_REDIS_PORT=6379
SPRING_REDIS_PASSWORD=
SPRING_REDIS_SSL=false

SPRING_ELASTICSEARCH_URIS=http://localhost:9200

# --- Messaging / Notification (Phase 5) ---
SOCKET_SERVER_URL=http://localhost:4000
SOCKET_INTERNAL_API_KEY=dev-secret-change-in-prod
NOTIFICATION_MESSAGE_COOLDOWN_MINUTES=2
NOTIFICATION_AGGREGATION_WINDOW_MINUTES=5
NOTIFICATION_CLEANUP_DAYS_TO_KEEP=90

JWT_SIGNER_KEY=replace-with-dev-secret-key
JWT_VALID_DURATION=3600
JWT_REFRESHABLE_DURATION=36000
COOKIE_SECURE=false
COOKIE_SAMESITE=Lax

GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_PROJECT_ID=
GEMINI_API_KEY=
HUGGING_FACE_KEY=

EMBEDDING_SERVICE_URL=http://localhost:8000
FAST_API_BASE_URL=http://localhost:8000
WEB_BASE_URL=http://localhost:5000
HELP_CENTER_URL=
COMPANY_ADDRESS=1 Vo Van Ngan, Thu Duc, TP. Ho Chi Minh, Viet Nam
DIGEST_ENABLED=true
DIGEST_BUILD_CRON=0 0 7 ? * MON
DIGEST_SEND_CRON=0 0 8 ? * MON
CACHE_USER_TTL=300

SUPPORT_EMAIL=support@careergraph.local
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_TRANSPORT_PROTOCOL=smtp
MAIL_SMTP_AUTH=true
MAIL_STARTTLS_ENABLE=true
MAIL_DEBUG=false

INTEGRATION_S3_ENDPOINT=
INTEGRATION_S3_ACCESS_KEY=
INTEGRATION_S3_SECRET_KEY=
INTEGRATION_S3_BUCKET=
INTEGRATION_S3_REGION=

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- Elasticsearch sync / embedding runtime ---
# Bật sync jobs khi app start.
APP_ES_SYNC_JOBS_ENABLED=false
# Bật sync candidates khi app start.
APP_ES_SYNC_CANDIDATES_ENABLED=false
# Cho phép fallback sang Gemini nếu local embedding lỗi.
APP_ES_ALLOW_GEMINI_FALLBACK=true
# true: local trước, Gemini sau. false: Gemini trước, local sau.
APP_EMBED_USE_LOCAL_FIRST=true
# Ghi đè riêng cho EmbedService nếu cần.
APP_EMBED_ALLOW_GEMINI_FALLBACK=true
# Số job thay đổi tối đa được embed trong một lần sync.
APP_ES_MAX_EMBEDDINGS_PER_RUN=50
# Số candidate thay đổi tối đa được embed trong một lần sync.
APP_ES_MAX_CANDIDATE_EMBEDDINGS_PER_RUN=30
# Bật/tắt toàn bộ cron sync.
APP_ES_CRON_ENABLED=true
# Bật cron jobs sync.
APP_ES_CRON_JOBS_ENABLED=true
# Bật cron candidates sync.
APP_ES_CRON_CANDIDATES_ENABLED=true
# Khoảng cách giữa 2 lần chạy jobs sync (ms).
APP_ES_CRON_JOBS_FIXED_DELAY_MS=120000
# Delay trước lần jobs sync đầu tiên (ms).
APP_ES_CRON_JOBS_INITIAL_DELAY_MS=120000
# Số job tối đa mỗi lần cron jobs chạy.
APP_ES_CRON_JOBS_BATCH_SIZE=25
# Khoảng cách giữa 2 lần chạy candidates sync (ms).
APP_ES_CRON_CANDIDATES_FIXED_DELAY_MS=240000
# Delay trước lần candidates sync đầu tiên (ms).
APP_ES_CRON_CANDIDATES_INITIAL_DELAY_MS=240000
# Số candidate tối đa mỗi lần cron candidates chạy.
APP_ES_CRON_CANDIDATES_BATCH_SIZE=10
# Số lần retry tối đa cho Spring AI.
SPRING_AI_RETRY_MAX_ATTEMPTS=1
# Có retry lỗi 4xx hay không.
SPRING_AI_RETRY_ON_CLIENT_ERRORS=false
# Không retry khi dính rate limit.
SPRING_AI_RETRY_EXCLUDE_ON_HTTP_CODES=429
# Backoff ban đầu trước lần retry đầu tiên.
SPRING_AI_RETRY_BACKOFF_INITIAL_INTERVAL=1ms
# Backoff tối đa.
SPRING_AI_RETRY_BACKOFF_MAX_INTERVAL=2ms
# Hệ số nhân backoff.
SPRING_AI_RETRY_BACKOFF_MULTIPLIER=2
# Số chiều vector embedding phải khớp mapping Elasticsearch.
EMBEDDING_SERVICE_EXPECTED_DIMENSIONS=3072

CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5000,http://localhost:5173,http://localhost:8000,https://thinz.io.vn,http://thinz.io.vn,http://api.thinz.io.vn,https://api.thinz.io.vn,http://hr.thinz.io.vn,https://hr.thinz.io.vn
CORS_ALLOWED_METHODS=*
CORS_ALLOWED_HEADERS=*

SECURITY_PUBLIC_ENDPOINTS=/auth/**,/jobs/**,/companies/**,/swagger-ui.html,/swagger-ui/**,/swagger-resources/**,/v3/api-docs,/v3/api-docs/**,/v3/api-docs.yaml,/api-docs/**,/webjars/**,/error,/actuator/health,/actuator/health/**
